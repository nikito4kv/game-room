# Пример переменных окружения. Скопируй в .env.local и заполни своими значениями.
# .env.local в git НЕ коммитится (см. .gitignore).

# --- LiveKit (медиа: голос, экран, комнаты) ---
# Серверные ключи — только на сервере, не в клиенте.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Серверный URL LiveKit (https/wss из дашборда LiveKit Cloud).
LIVEKIT_URL=
# Публичный wss-URL для клиента (можно совпадать с LIVEKIT_URL в форме wss://).
NEXT_PUBLIC_LIVEKIT_URL=

# --- Upstash Redis (приватное состояние комнат + rate limiting + статистика) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Базовый URL (опционально; для абсолютных ссылок в OG-метаданных) ---
# На Vercel подставляется автоматически (VERCEL_URL); локально можно не задавать.
NEXT_PUBLIC_APP_URL=

# --- PostHog (аналитика, Cloud EU) ---
# Project API key — публичный, шлётся с клиента (posthog-js).
NEXT_PUBLIC_POSTHOG_KEY=
# Хост приёма событий (ingestion) для региона EU.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Тот же project API key для серверного posthog-node (события из вебхука).
POSTHOG_KEY=

# --- PostHog: только для экспортного скрипта (npm run analytics:export) ---
# Personal API key (создаётся в настройках PostHog, scope: query read).
POSTHOG_PERSONAL_API_KEY=
# ID проекта PostHog (число из URL проекта).
POSTHOG_PROJECT_ID=
# Хост API (app) для региона EU. Внимание: отличается от ingestion-хоста выше.
POSTHOG_HOST=https://eu.posthog.com
